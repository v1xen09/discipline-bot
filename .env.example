# ── Telegram (обязательно) ────────────────────────────────────────────
TELEGRAM_TOKEN=

# ── LM Studio ─────────────────────────────────────────────────────────
# Запусти LM Studio, загрузи модель, включи Server на вкладке Developer.
# При запуске через docker compose up используй адрес ниже:
# LMSTUDIO_BASE_URL=http://host.docker.internal:4321/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TIMEOUT=180

# ── faster-whisper (STT) ──────────────────────────────────────────────
# Размер модели: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Яндекс.Погода (опционально) ──────────────────────────────────────
# Ключ: https://developer.tech.yandex.ru/ → тестовый план (50 req/day, бесплатно)
YANDEX_WEATHER_KEY=fa0f11a5-fd86-48c2-b07f-ef6e45a933a8

# ── Прочее ────────────────────────────────────────────────────────────
DATABASE_PATH=tmanager.db
BOT_NAME=TManager
