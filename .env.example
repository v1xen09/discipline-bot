# ── Режим развёртывания ───────────────────────────────────────────────
# local  → LM Studio (LLM) + faster-whisper (STT), всё работает на ПК
# cloud  → YandexGPT (LLM) + Yandex SpeechKit (STT), для Yandex Cloud
DEPLOYMENT_MODE=local

# ── Telegram (обязательно) ────────────────────────────────────────────
TELEGRAM_TOKEN=

# ── LM Studio (нужно только при DEPLOYMENT_MODE=local) ───────────────
# Запусти LM Studio, загрузи модель, включи Server на вкладке Developer.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TIMEOUT=180

# ── Яндекс Cloud (нужно только при DEPLOYMENT_MODE=cloud) ────────────
# API-ключ сервисного аккаунта с ролями ai.languageModels.user + ai.speechkit.user
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite

# ── Прочее ────────────────────────────────────────────────────────────
DATABASE_PATH=tmanager.db
BOT_NAME=TManager

# ── Ручное переопределение провайдеров (опционально) ─────────────────
# Устанавливаются автоматически из DEPLOYMENT_MODE.
# Раскомментируй для смешанных конфигураций (например, YandexGPT + Whisper).
# AI_PROVIDER=yandex
# SPEECH_PROVIDER=whisper

# ── faster-whisper (только при SPEECH_PROVIDER=whisper) ──────────────
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
